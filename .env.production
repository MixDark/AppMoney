# Entorno (development | production)
FLASK_ENV=production

# Servidor
SERVER_HOST=0.0.0.0
SERVER_PORT=7700
SERVER_THREADS=4

# Base de datos - Producción (Docker)
DB_HOST=mysql
DB_USER=appuser
DB_PASSWORD=your-secure-database-password
DB_NAME=app_money

# Base de datos - MySQL Root
MYSQL_ROOT_PASSWORD=your-secure-root-password

# Flask
FLASK_SECRET_KEY=your-secure-secret-key-generate-with-secrets-module
FLASK_DEBUG=False
SESSION_TIMEOUT=1800
